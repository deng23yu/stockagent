# stockagent 配置示例。复制为 stockagent.yaml 并填入你的 key，
# 或放到 ~/.stockagent.yaml。所有项也可被环境变量 / flag 覆盖:
#   STOCKAGENT_BASE_URL / STOCKAGENT_API_KEY / STOCKAGENT_MODEL
llm:
  # 任意 OpenAI 兼容端点:
  #   DeepSeek  https://api.deepseek.com
  #   通义千问  https://dashscope.aliyuncs.com/compatible-mode/v1
  #   Kimi      https://api.moonshot.cn/v1
  #   OpenAI    https://api.openai.com/v1
  #   Ollama    http://localhost:11434/v1
  base_url: https://api.deepseek.com
  api_key: sk-your-api-key
  model: deepseek-chat
  # temperature: 0.3   # 可选; 不设置则由服务端默认值决定
                         # (kimi-for-coding 等模型只接受 temperature=1 时必须留空)
